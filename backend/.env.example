# Seabay Backend Configuration
SEABAY_DATABASE_URL=postgresql+asyncpg://seabay:seabay@localhost:5432/seabay
SEABAY_REDIS_URL=redis://localhost:6379/0
SEABAY_DEBUG=true
SEABAY_REGION=intl

# CORS allowed origins (comma-separated). Use "*" for development only.
# SEABAY_CORS_ORIGINS=https://seabay.ai,https://www.seabay.ai

# Passport receipt signing key (REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))")
# SEABAY_PASSPORT_SIGNING_KEY=
